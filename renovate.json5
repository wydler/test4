{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'helpers:pinGitHubActionDigests',
  ],
  commitMessagePrefix: 'chore(deps):',
  timezone: 'Europe/Berlin',
  prHourlyLimit: 0,
  prConcurrentLimit: 0,
  automerge: false,
  enabledManagers: [
    'github-actions',
    'custom.regex',
    'dockerfile',
  ],

  customManagers: [
    {
      customType: 'regex',
      description: 'Match Alpine versions in FROM statements',
      managerFilePatterns: [
        '/(^|/)Dockerfile$/',
      ],
      matchStrings: [
        'FROM\\s+alpine:(?<currentValue>[0-9.]+)',
      ],
      depNameTemplate: 'alpine',
      datasourceTemplate: 'docker',
    },
  ],

  packageRules: [
    {
      matchCategories: [
        'docker',
      ],
      enabled: true,
    },
    {
      // ===========================================================================
      // Docker Repository - Alpine
      // ===========================================================================  
      description: 'Alpine base image updates',
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'alpine',
      ],
      versioning: 'docker',
      rangeStrategy: 'pin',
      labels: [
        'dependencies',
        'docker',
      ],
      draftPR: true,
      additionalBranchPrefix: 'docker/',
      branchTopic: '{{depNameSanitized}}-{{newVersion}}',
      commitMessageTopic: '{{depName}}',
      commitMessageExtra: 'from {{currentVersion}} to {{newVersion}}',
    },
    {
      // ===========================================================================
      // GitHub Actions
      // ===========================================================================  
      matchManagers: [
        'github-actions',
      ],
      labels: [
        'dependencies',
        'github_actions',
      ],
      matchPackageNames: [
        '*',
      ],
      draftPR: true,
      additionalBranchPrefix: 'github_action/',
      branchTopic: '{{depNameSanitized}}-{{newVersion}}',
      commitMessageTopic: '{{depName}}',
      commitMessageExtra: 'from {{currentVersion}} to {{newVersion}}',
    },
  ],
}
