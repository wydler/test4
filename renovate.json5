{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'helpers:pinGitHubActionDigests',
  ],
  commitMessagePrefix: 'chore(deps):',
  timezone: 'Europe/Berlin',
  prHourlyLimit: 0,
  prConcurrentLimit: 0,
  automerge: false,
  enabledManagers: [
    'github-actions',
    'dockerfile',
  ],

  packageRules: [
    {
      // ===========================================================================
      // Aktiviert Renovate-Regeln für Docker-basierte Dependencies
      // ===========================================================================  
      matchCategories: [
        'docker',
      ],
      enabled: true,
    },
    {
      // ===========================================================================
      // GitHub Actions
      // ===========================================================================  
      matchManagers: [
        'github-actions',
      ],
      labels: [
        'dependencies',
        'github_actions',
      ],
      matchPackageNames: [
        '*',
      ],
      draftPR: true,
      additionalBranchPrefix: 'github_action/',
      branchTopic: '{{depNameSanitized}}-{{newVersion}}',
      commitMessageTopic: '{{depName}}',
      commitMessageExtra: 'from {{currentVersion}} to {{newVersion}}',
    },
    {
      // ===========================================================================
      // Docker Repository - Pyhton
      // =========================================================================== 
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'python',
      ],
      matchFileNames: [
        'docker/parsedmarc/**',
      ],
      versioning: 'docker',
      ignoreUnstable: true,
      pinDigests: true,
      labels: [
        'dependencies',
        'docker',
      ],
      draftPR: true,
      additionalBranchPrefix: 'docker/',
      branchTopic: '{{depNameSanitized}}-{{newVersion}}',
      commitMessageTopic: '{{depName}}',
      commitMessageExtra: 'from {{currentVersion}} to {{newVersion}}',
    },
    {
      // ===========================================================================
      // Docker Repository - Pyhton
      // =========================================================================== 
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'elasticsearch',
        'kibana',
      ],
      // matchFileNames: [
      //  'docker/parsedmarc/**',
      // ],
      versioning: 'docker',
      ignoreUnstable: true,
      pinDigests: true,
      labels: [
        'dependencies',
        'docker',
      ],
      allowedVersions: '<9.0.0',
      draftPR: true,
      additionalBranchPrefix: 'docker/',
      branchTopic: '{{depNameSanitized}}-{{newVersion}}',
      commitMessageTopic: '{{depName}}',
      commitMessageExtra: 'from {{currentVersion}} to {{newVersion}}',
    },
  ],
}
