{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'helpers:pinGitHubActionDigests',
  ],
  commitMessagePrefix: 'chore(deps):',
  timezone: 'Europe/Berlin',
  prHourlyLimit: 0,
  prConcurrentLimit: 0,
  automerge: false,

  // Regex-basierte Manager für Selfoss
  "regexManagers": [
    {
      "fileMatch": ["^selfoss\\.snapshot$"],
      "matchStrings": [
        // Extrahiere die aktuelle VERSION
        "VERSION=(?<currentValue>\\S+)"
      ],
      // Nutze einen Custom Datasource, weil Cloudsmith nicht standardmäßig unterstützt wird
      "datasourceTemplate": "custom",
      "depNameTemplate": "selfoss",
      "versioningTemplate": "semver",
      "registryUrls": [
        "https://api.cloudsmith.io/v1/packages/fossar/selfoss-git/"
      ],
      // Template, um aus der JSON-Antwort die Version zu extrahieren
      "extractVersionTemplate": "{{{json.version}}}"
    }
  ],

  // Update-Regeln für Dockerfile und GitHub Actions
  "packageRules": [
    {
      "managers": ["dockerfile"],
      "enabled": true
    },
    {
      "managers": ["github-actions"],
      "enabled": true
    }
  ]
}
