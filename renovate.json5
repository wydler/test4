{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'helpers:pinGitHubActionDigests',
  ],
  commitMessagePrefix: 'chore(deps):',
  timezone: 'Europe/Berlin',
  prHourlyLimit: 0,
  prConcurrentLimit: 0,
  automerge: false,
  enabledManagers: [
    'github-actions',
    'dockerfile',
    'pip_requirements',
  ],
  pip_requirements: {
    managerFilePatterns: [
      '/^docker/parsedmarc/requirements\\.txt$/',
    ],
  },
  packageRules: [
    {
      matchManagers: [
        'pip_requirements',
      ],
      labels: [
        'dependencies',
        'apps',
      ],
      draftPR: true,
      additionalBranchPrefix: 'github_action/',
      branchTopic: '{{depNameSanitized}}-{{newVersion}}',
      commitMessageTopic: '{{depName}}',
      commitMessageExtra: 'from {{currentVersion}} to {{newVersion}}',
    },
    {
      matchCategories: [
        'docker',
      ],
      enabled: true,
    },
    {
      matchManagers: [
        'github-actions',
      ],
      matchPackageNames: [
        '*',
      ],
      labels: [
        'dependencies',
        'github_actions',
      ],
      draftPR: true,
      additionalBranchPrefix: 'github_action/',
      branchTopic: '{{depNameSanitized}}-{{newVersion}}',
      commitMessageTopic: '{{depName}}',
      commitMessageExtra: 'from {{currentVersion}} to {{newVersion}}',
    },
    {
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'python',
        'ghcr.io/maxmind/geoipupdate',
        'nginx',
        'alpine',
      ],
      versioning: 'docker',
      ignoreUnstable: true,
      pinDigests: true,
      labels: [
        'dependencies',
        'docker',
      ],
      draftPR: true,
      additionalBranchPrefix: 'docker/',
      branchTopic: '{{depNameSanitized}}-{{newVersion}}',
      commitMessageTopic: '{{depName}}',
      commitMessageExtra: 'from {{currentVersion}} to {{newVersion}}',
    },
    {
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'docker.elastic.co/elasticsearch/elasticsearch',
        'docker.elastic.co/kibana/kibana',
      ],
      versioning: 'docker',
      ignoreUnstable: true,
      pinDigests: true,
      labels: [
        'dependencies',
        'docker',
      ],
      allowedVersions: '<9.0.0',
      draftPR: true,
      additionalBranchPrefix: 'docker/',
      branchTopic: '{{depNameSanitized}}-{{newVersion}}',
      commitMessageTopic: '{{depName}}',
      commitMessageExtra: 'from {{currentVersion}} to {{newVersion}}',
    },
    {
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'wydler/logrotate',
      ],
      versioning: 'docker',
      ignoreUnstable: true,
      pinDigests: true,
      labels: [
        'dependencies',
        'docker',
      ],
      draftPR: true,
      additionalBranchPrefix: 'docker/',
      branchTopic: '{{depNameSanitized}}-{{newVersion}}',
      commitMessageTopic: '{{depName}}',
      commitMessageExtra: 'from {{currentVersion}} to {{newVersion}}',
    },
  ],
}
