{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  commitMessagePrefix: 'chore(deps):',
  timezone: 'Europe/Berlin',
  prHourlyLimit: 0,
  prConcurrentLimit: 0,
  automerge: false,
  packageRules: [
    {
      matchCategories: [
        'docker',
      ],
      enabled: true,
    },
    {
      description: 'Alpine base image updates',
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'alpine',
      ],
      versioning: 'docker',
      automerge: false,
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      description: 'Match Alpine versions in FROM statements',
      managerFilePatterns: [
        '/(^|/)Dockerfile$/',
      ],
      matchStrings: [
        'FROM\\s+alpine:(?<currentValue>[0-9.]+)',
      ],
      depNameTemplate: 'alpine',
      datasourceTemplate: 'docker',
    },
  ],
}
