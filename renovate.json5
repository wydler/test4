{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  commitMessagePrefix: 'chore(deps):',
  timezone: 'Europe/Berlin',
  prHourlyLimit: 0,
  prConcurrentLimit: 0,
  automerge: false,

  docker: {
    enabled: true
  },

  packageRules: [
    {
      description: "Alpine base image updates",
      matchDatasources: ["docker"],
      matchPackageNames: ["alpine"],
      versioning: "docker",
      groupName: "alpine updates",
      automerge: false
    }
  ],

  regexManagers: [
    {
      description: "Match Alpine versions in FROM statements",
      fileMatch: ["(^|/)Dockerfile$"],
      matchStrings: [
        "FROM\\s+alpine:(?<currentValue>[0-9.]+)"
      ],
      depNameTemplate: "alpine",
      datasourceTemplate: "docker"
    }
  ]
}
