{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'helpers:pinGitHubActionDigests',
  ],
  commitMessagePrefix: 'chore(deps):',
  timezone: 'Europe/Berlin',
  prHourlyLimit: 0,
  prConcurrentLimit: 0,
  automerge: false,
  enabledManagers: [
    'custom.regex',
  ],

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^selfoss\\.snapshot$/"],
      "matchStrings": ["VERSION=(?<currentValue>.*)"],
      "depNameTemplate": "selfoss",
      "datasourceTemplate": "custom.selfoss",
      "versioningTemplate": "loose"
    }
  ],
  "customDatasources": {
    "selfoss": {
      "defaultRegistryUrlTemplate": "https://api.cloudsmith.io/packages/fossar/selfoss-git/?page=1&page_size=1",
      "transformTemplates": [
        '{ "releases": [ { "version": "{{{body.version}}}" } ] }'
      ]
    }
  },

  "packageRules": [
    {
      "matchPackageNames": ["selfoss"],
      "commitMessageTopic": "selfoss",
      "commitMessageExtra": "to {{newVersion}}",
      "draftPR": false,
      "additionalBranchPrefix": "plugin/",
      "branchTopic": "{{depNameSanitized}}-{{newVersion}}",
      "prBodyNotes": ["Quelle: Cloudsmith API"]
    }
  ]
}
