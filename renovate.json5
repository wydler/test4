{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'helpers:pinGitHubActionDigests',
  ],
  commitMessagePrefix: 'chore(deps):',
  timezone: 'Europe/Berlin',
  prHourlyLimit: 0,
  prConcurrentLimit: 0,
  automerge: false,
  enabledManagers: [
    'github-actions',
    'dockerfile',
  ],


  packageRules: [
    {
      // ===========================================================================
      // Aktiviert Renovate-Regeln für Docker-basierte Dependencies
      // ===========================================================================  
      matchCategories: [
        'docker',
      ],
      enabled: true,
    },
    {
      // ===========================================================================
      // GitHub Actions
      // ===========================================================================  
      matchManagers: [
        'github-actions',
      ],
      matchPackageNames: [
        '*',
      ],
      labels: [
        'dependencies',
        'github_actions',
      ],
      draftPR: true,
      additionalBranchPrefix: 'github_action/',
      branchTopic: '{{depNameSanitized}}-{{#if newVersion}}{{newVersion}}{{else}}{{currentValue}}-{{newDigest}}{{/if}}',
      commitMessageTopic: '{{depName}}',
      commitMessageExtra: '{{#if newVersion}}from {{currentVersion}} to {{newVersion}}{{else}}{{newValue}} from {{currentDigestShort}} to {{newDigestShort}}{{/if}}',
    },
    {
      // ===========================================================================
      // Docker Repository - Nginx
      // =========================================================================== 
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'nginx',
      ],
      versioning: 'docker',
      pinDigests: true,
      labels: [
        'dependencies',
        'docker',
      ],
      draftPR: true,
      additionalBranchPrefix: 'docker/',
      branchTopic: '{{depNameSanitized}}-{{#if newVersion}}{{newVersion}}{{else}}{{currentValue}}-{{newDigest}}{{/if}}',
      commitMessageTopic: '{{depName}}',
      commitMessageExtra: '{{#if newVersion}}from {{currentVersion}} to {{newVersion}}{{else}}{{newValue}} from {{currentDigestShort}} to {{newDigestShort}}{{/if}}',
    },
    {
      // ===========================================================================
      // Docker Repository - Nginx
      // =========================================================================== 
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'ubuntu',
      ],
      versioning: 'ubuntu',
      // allowedVersions: '/^22\\.04$/',
      allowedVersions: '22.04',
      // matchUpdateTypes: [
      //   'digest',
      // ],
      // matchCurrentValue: '22.04',
      pinDigests: true,
      labels: [
        'dependencies',
        'docker',
      ],
      draftPR: true,
      additionalBranchPrefix: 'docker/',
      branchTopic: '{{depNameSanitized}}-{{#if newVersion}}{{newVersion}}{{else}}{{currentValue}}-{{newDigest}}{{/if}}',
      commitMessageTopic: '{{depName}}',
      commitMessageExtra: '{{#if newVersion}}from {{currentVersion}} to {{newVersion}}{{else}}{{newValue}} from {{currentDigestShort}} to {{newDigestShort}}{{/if}}',
    },
  ],
}
