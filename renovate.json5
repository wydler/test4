{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'helpers:pinGitHubActionDigests',
  ],
  commitMessagePrefix: 'chore(deps):',
  timezone: 'Europe/Berlin',
  prHourlyLimit: 0,
  prConcurrentLimit: 0,
  automerge: false,
  enabledManagers: [
    'github-actions',
    'dockerfile',
  ],

  // Regex Manager für Dockerfile PHP Base Image
  regexManagers: [
    {
      description: "PHP 8.4 FPM Docker image tracking",

      fileMatch: [
        "(^|/)Dockerfile$"
      ],

      matchStrings: [
        "FROM\\s+php:(?<currentValue>8\\.4\\.[0-9]+-fpm)"
      ],

      datasourceTemplate: "docker",
      depNameTemplate: "php",

      // sorgt dafür, dass Docker Tags korrekt verglichen werden
      versioningTemplate: "docker",

      // 🔒 HARD LOCK: verhindert 8.5, 9.x etc.
      allowedVersions: ">=8.4.0 <8.5.0",
    }
  ],

  packageRules: [
    {
      // ===========================================================================
      // Aktiviert Renovate-Regeln für Docker-basierte Dependencies
      // ===========================================================================  
      matchCategories: [
        'docker',
      ],
      enabled: true,
    },
    {
      // ===========================================================================
      // GitHub Actions
      // ===========================================================================  
      matchManagers: [
        'github-actions',
      ],
      matchPackageNames: [
        '*',
      ],
      labels: [
        'dependencies',
        'github_actions',
      ],
      draftPR: true,
      additionalBranchPrefix: 'github_action/',
      branchTopic: '{{depNameSanitized}}-{{#if newVersion}}{{newVersion}}{{else}}{{currentValue}}-{{newDigest}}{{/if}}',
      commitMessageTopic: '{{depName}}',
      commitMessageExtra: '{{#if newVersion}}from {{currentVersion}} to {{newVersion}}{{else}}{{newValue}} from {{currentDigestShort}} to {{newDigestShort}}{{/if}}',
    },
    {
      // ===========================================================================
      // Docker Repository - Alpine, Nginx, PHP-FPM
      // =========================================================================== 
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'alpine',
        'nginx',
      ],
      versioning: 'docker',
      ignoreUnstable: true,
      pinDigests: true,
      labels: [
        'dependencies',
        'docker',
      ],
      draftPR: true,
      additionalBranchPrefix: 'docker/',
      branchTopic: '{{depNameSanitized}}-{{#if newVersion}}{{newVersion}}{{else}}{{currentValue}}-{{newDigest}}{{/if}}',
      commitMessageTopic: '{{depName}}',
      commitMessageExtra: '{{#if newVersion}}from {{currentVersion}} to {{newVersion}}{{else}}{{newValue}} from {{currentDigestShort}} to {{newDigestShort}}{{/if}}',
    },
    {
      // ===========================================================================
      // Docker Repository - PHP-FPM
      // =========================================================================== 
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'php',
      ],
      versioning: 'docker',
      ignoreUnstable: true,
      pinDigests: true,
      labels: [
        'dependencies',
        'docker',
      ],
      draftPR: true,
      additionalBranchPrefix: 'docker/',
      branchTopic: '{{depNameSanitized}}-{{#if newVersion}}{{newVersion}}{{else}}{{currentValue}}-{{newDigest}}{{/if}}',
      commitMessageTopic: '{{depName}}',
      commitMessageExtra: '{{#if newVersion}}from {{currentVersion}} to {{newVersion}}{{else}}{{newValue}} from {{currentDigestShort}} to {{newDigestShort}}{{/if}}',
    },
  ],
}
