{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'helpers:pinGitHubActionDigests',
  ],
  commitMessagePrefix: 'chore(deps):',
  timezone: 'Europe/Berlin',
  prHourlyLimit: 0,
  prConcurrentLimit: 0,
  automerge: false,

  // Regex-basierte Manager für Selfoss
  "regexManagers": [
    {
      // Nur die Snapshot-Datei für Selfoss
      "fileMatch": ["^selfoss\\.snapshot$"],

      // Regex, um die aktuelle Version aus der Datei zu holen
      "matchStrings": [
        "VERSION=(?<currentValue>\\S+)"
      ],

      // Custom Datasource für Cloudsmith
      "datasourceTemplate": "custom",
      "depNameTemplate": "selfoss",
      "versioningTemplate": "semver",

      // Cloudsmith API URL für das Selfoss-Paket
      "urlTemplate": "https://api.cloudsmith.io/v1/packages/fossar/selfoss-git/lggOWzAwE6Dq/",

      // Template, um die Version aus der API-Antwort zu ziehen
      "extractVersionTemplate": "{{{json.version}}}"
    }
  ],

  // Alles andere deaktivieren, nur selfoss-Updates
  "packageRules": [
    {
      "matchPackageNames": ["selfoss"],
      "enabled": true
    }
  ]
}
